# EAS Build ignore file
# Based on .gitignore but keeps Firebase config files for local builds

# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.keystore
!android/app/debug.keystore
*.mobileprovision
*.apk
*.aab

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env*.local
.env

# NOTE: google-services.json and GoogleService-Info.plist are NOT ignored here
# so they are included in local EAS builds

# typescript
*.tsbuildinfo

app-example
.firebase/logs/vsce-debug.log
