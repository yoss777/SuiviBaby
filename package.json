    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "test": "jest",
    "test:rules": "firebase emulators:exec --only firestore 'npx jest __tests__/firestore.rules.test.ts --config jest.config.rules.js'",
