    "test:all": "jest && jest --rootDir functions --testMatch='**/__tests__/**/*.test.js'",
    "test:coverage": "jest --coverage",
    "typecheck": "tsc --noEmit",
    "postinstall": "node ./scripts/patch-expo.js",
    "update-app-config": "node ./scripts/updateAppConfig.mjs"
  },
