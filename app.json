{
  "expo": {
    "name": "Suivi Baby",
    "slug": "Samaye",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "suivibaby",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Autoriser $(PRODUCT_NAME) à accéder à votre photothèque pour ajouter des moments.",
        "NSPhotoLibraryAddUsageDescription": "Autoriser $(PRODUCT_NAME) à enregistrer des photos dans votre photothèque.",
        "NSCameraUsageDescription": "Autoriser $(PRODUCT_NAME) à utiliser l’appareil photo pour ajouter des moments.",
        "NSMicrophoneUsageDescription": "Autoriser $(PRODUCT_NAME) à utiliser le microphone pour les commandes vocales.",
        "NSSpeechRecognitionUsageDescription": "Autoriser $(PRODUCT_NAME) à utiliser la reconnaissance vocale pour les commandes vocales."
      },
      "bundleIdentifier": "com.tesfa.suivibaby",
      "buildNumber": "1"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "permissions": [
        "RECORD_AUDIO",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ],
      "package": "com.tesfa.suivibaby",
      "compileSdkVersion": 35,
      "targetSdkVersion": 35,
      "minSdkVersion": 21,
      "versionCode": 1
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      [
        "@sentry/react-native/expo",
        {
          "organization": "tesfa-f9",
          "project": "suivibaby"
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "newArchEnabled": true
          },
          "android": {
            "newArchEnabled": true,
            "enableProguardInReleaseBuilds": true,
            "enableShrinkResourcesInReleaseBuilds": true
          }
        }
      ],
      "expo-secure-store",
      "expo-apple-authentication",
      "@react-native-google-signin/google-signin",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/notification-icon.png",
          "color": "#0891b2"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "0c759940-43b8-4cb3-9dc5-d0faa2eacf41"
      }
    }
  }
}
